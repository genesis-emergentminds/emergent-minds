# Cloudflare Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore
#
# Find these in Cloudflare Dashboard → Overview (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Matrix Configuration
# Genesis admin account (space admin — NOT for bots)
MATRIX_ACCESS_TOKEN=your_genesis_matrix_token_here

# Threshold bot account (separate account, minimal permissions)
# THRESHOLD_MATRIX_TOKEN=your_threshold_bot_token_here
# THRESHOLD_MATRIX_USER=@threshold-emergent-minds:matrix.org
# THRESHOLD_MATRIX_HOMESERVER=https://matrix.org

# Gemini API (for image generation)
# GEMINI_API_KEY=your_gemini_key_here
